{
  "rewrites": [
    { "source": "/", "destination": "/dtd2.1.html" },
    { "source": "/tuner", "destination": "/tuner.html" }
  ],
  "functions": {
    "api/*.js": { "includeFiles": "arch-config.json" }
  },
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/tuner",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
